rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeStaff() {
      return signedIn() && userProfile().data.active == true;
    }

    function adminRole() {
      return activeStaff() && userProfile().data.role == 'admin';
    }

    function operationsRole() {
      return activeStaff() && userProfile().data.role in ['admin', 'office', 'supervisor'];
    }

    function inventoryRole() {
      return activeStaff() && userProfile().data.role in ['admin', 'office', 'supervisor', 'inventory'];
    }

    function technicianRole() {
      return activeStaff() && userProfile().data.role == 'technician';
    }

    function adminOrSupervisor() {
      return activeStaff() && userProfile().data.role in ['admin', 'supervisor'];
    }

    function assignedToTechnician() {
      return technicianRole()
        && (
          request.auth.uid in resource.data.technicianIds
          || ('staffId' in userProfile().data && userProfile().data.staffId in resource.data.technicianIds)
          || ('vanId' in userProfile().data && userProfile().data.vanId == resource.data.vanId)
        );
    }

    function workOrderData(workOrderId) {
      return get(/databases/$(database)/documents/workOrders/$(workOrderId)).data;
    }

    function assignedToWorkOrderId(workOrderId) {
      return technicianRole()
        && (
          request.auth.uid in workOrderData(workOrderId).technicianIds
          || ('staffId' in userProfile().data && userProfile().data.staffId in workOrderData(workOrderId).technicianIds)
          || ('vanId' in userProfile().data && userProfile().data.vanId == workOrderData(workOrderId).vanId)
        );
    }

    function technicianWorkOrderFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'departedAt',
        'arrivedAt',
        'workStartedAt',
        'pendingAt',
        'completedAt',
        'pendingReason',
        'pendingAction',
        'requiresSecondVisit',
        'technicianDraftUpdatedAt',
        'statusHistory',
        'diagnosis',
        'workPerformed',
        'recommendation',
        'customerSignature',
        'measurements',
        'photos',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if activeStaff() && (request.auth.uid == userId || adminRole());
      allow write: if false;
    }

    match /userAuditLogs/{logId} {
      allow read: if adminRole();
      allow write: if false;
    }

    match /clients/{clientId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /clientDeletionLogs/{logId} {
      allow read, create: if adminOrSupervisor();
      allow update, delete: if false;
    }

    match /properties/{propertyId} {
      allow read: if activeStaff();
      allow create, update, delete: if operationsRole();
    }

    match /services/{serviceId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /staffProfiles/{staffId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /vans/{vanId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /dailyVanAssignments/{assignmentId} {
      allow read: if activeStaff();
      allow create, update, delete: if operationsRole();
    }

    match /staffAbsences/{absenceId} {
      allow read: if activeStaff();
      allow create, update, delete: if operationsRole();
    }

    match /vanMaintenanceLogs/{logId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /vanHalfDaySchedules/{scheduleId} {
      allow read: if activeStaff();
      allow create, update, delete: if operationsRole();
    }

    match /calendarClosures/{closureId} {
      allow read: if activeStaff();
      allow create, update, delete: if operationsRole();
    }

    match /businessSettings/{settingId} {
      allow read: if activeStaff();
      allow create, update: if operationsRole();
      allow delete: if adminOrSupervisor();
    }

    match /warehouseInventory/{itemId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /toolCatalog/{toolId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /vanToolAssets/{assetId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /inventoryChecks/{checkId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /inventoryCheckEntries/{entryId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /inventoryEvidence/{evidenceId} {
      allow read: if activeStaff();
      allow create, update, delete: if inventoryRole();
    }

    match /workOrders/{workOrderId} {
      allow read: if activeStaff();
      allow create: if operationsRole();
      allow update: if operationsRole() || (assignedToTechnician() && technicianWorkOrderFieldsOnly());
      allow delete: if adminOrSupervisor();
    }

    match /workOrderUnits/{unitId} {
      allow read: if activeStaff();
      allow create: if operationsRole()
        || (assignedToWorkOrderId(request.resource.data.workOrderId)
          && request.resource.data.createdByUserId == request.auth.uid);
      allow update: if operationsRole()
        || (assignedToWorkOrderId(resource.data.workOrderId)
          && request.resource.data.workOrderId == resource.data.workOrderId);
      allow delete: if operationsRole()
        || assignedToWorkOrderId(resource.data.workOrderId);
    }

    match /workOrderEvidence/{evidenceId} {
      allow read: if activeStaff();
      allow create: if operationsRole()
        || (assignedToWorkOrderId(request.resource.data.workOrderId)
          && request.resource.data.uploadedByUserId == request.auth.uid);
      allow update: if operationsRole()
        || (assignedToWorkOrderId(resource.data.workOrderId)
          && resource.data.uploadedByUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note', 'updatedAt']));
      allow delete: if operationsRole()
        || (assignedToWorkOrderId(resource.data.workOrderId)
          && resource.data.uploadedByUserId == request.auth.uid);
    }

    match /whatsappOutboundQueue/{messageId} {
      allow read: if operationsRole();
      allow create: if operationsRole()
        && request.resource.data.status == 'queued';
      allow update, delete: if false;
    }

    match /whatsappMessages/{messageId} {
      allow read: if operationsRole();
      allow write: if false;
    }

    match /whatsappMessageStatuses/{statusId} {
      allow read: if operationsRole();
      allow write: if false;
    }

    match /whatsappWebhookEvents/{eventId} {
      allow read: if adminOrSupervisor();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
