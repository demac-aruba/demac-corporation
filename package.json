{
  "name": "demac-corporation",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.4",
    "expo-image-picker": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "libphonenumber-js": "^1.13.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "patch:inventory": "node scripts/runInventoryUnitPatch.cjs && node scripts/patchInventoryThumbnails.cjs && node scripts/patchInventoryThumbnailFallback.cjs",
    "patch:payroll": "node scripts/patchPayrollStartDateStage1.cjs && node scripts/patchPayrollStartDateStage2.cjs",
    "patch:all": "npm run patch:inventory && npm run patch:payroll",
    "prestart": "npm run patch:all",
    "start": "expo start",
    "preandroid": "npm run patch:all",
    "android": "expo start --android",
    "preios": "npm run patch:all",
    "ios": "expo start --ios",
    "preweb": "npm run patch:all",
    "web": "expo start --web",
    "pretypecheck": "npm run patch:all",
    "typecheck": "tsc --noEmit",
    "prebuild:web": "npm run patch:all",
    "build:web": "expo export --platform web"
  },
  "private": true
}
